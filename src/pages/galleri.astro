    ],
  },
  {
    label: "Some & Streetstyle",
    images: [
      { src: "/billeder/GettyImages-1848360615.jpg", caption: "" },
      { src: "/billeder/GettyImages-1471729712.jpg", caption: "" },
      { src: "/billeder/GettyImages-2178700684.jpg", caption: "" },
