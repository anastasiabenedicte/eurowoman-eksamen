  },
  {
    label: "Lookbooks",
    images: [
      { src: "/billeder/03.jpg",                                         caption: "" },
      { src: "/billeder/04.jpg",                                         caption: "" },
      { src: "/billeder/08.jpg",                                         caption: "" },
      { src: "/billeder/3B11B4A6-6733-4EAE-93A8-B2CFC7F9090E.JPG",     caption: "" },
      { src: "/billeder/E469D638-59D4-4547-B28E-FDAB683CE12F.JPG",      caption: "" },
      { src: "/billeder/GettyImages-1473362160.jpg",                     caption: "" },
    ],
  },
  {
    label: "Kunst & Arkiv",
    images: [
      { src: "/billeder/GettyImages-160161046.jpg",  caption: "Sophia Loren" },
      { src: "/billeder/GettyImages-111301247.jpg",  caption: "" },
      { src: "/billeder/GettyImages-74258633.jpg",   caption: "Leonard Cohen" },
      { src: "/billeder/GettyImages-86203874.jpg",   caption: "Leonard Cohen" },
      { src: "/billeder/GettyImages-1155693767.jpg", caption: "Egon Schiele" },
