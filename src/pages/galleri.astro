---

<MainLayout title="Galleri">

  <!-- Hero -->
  <section class="border-b border-gray-100 px-12 py-14 text-center">
    <p class="text-[10px] tracking-widest uppercase text-gray-400">Galleri</p>
  </section>

  <!-- Sektioner -->
  {sections.map((section) => (
    <section class="border-b border-gray-100">
      <div class="px-12 pt-10 pb-8">
        <p class="text-[10px] tracking-widest uppercase text-gray-400">{section.label}</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3">
        {section.images.map((img) => (
          <div class="flex flex-col items-center p-4 md:p-8 border-t border-gray-100">
            <img
              src={img.src}
              alt={img.caption}
              class="w-full h-auto max-h-[520px] object-contain hover:scale-[1.02] transition-transform duration-500"
            />
            {img.caption && (
              <p class="mt-3 text-[10px] tracking-widest uppercase text-gray-400 self-start">{img.caption}</p>
            )}
          </div>
        ))}
      </div>
    </section>
  ))}

</MainLayout>
