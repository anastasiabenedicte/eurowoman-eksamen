---
import MainLayout from "../layouts/MainLayout.astro";
import { articles } from "../data/articles";

const categories = ["Alt", "Mode", "Skønhed", "Interview", "Livsstil", "Rejse", "Kultur"];
const featured = articles.find((a) => a.featured)!;
const rest = articles.filter((a) => !a.featured);
---

<MainLayout title="Artikler">
  <div x-data="{ activeCategory: 'Alt' }">

    <!-- Kategori filter -->
    <div class="border-b border-gray-100 px-6 md:px-12 py-4 flex items-center gap-4 md:gap-8 overflow-x-auto">
      {categories.map((cat) => (
        <button
          type="button"
          @click={`activeCategory = '${cat}'`}
          :class={`activeCategory === '${cat}' ? 'text-black border-b border-black pb-0.5' : 'text-gray-400 hover:text-black'`}
          class="text-[10px] tracking-widest uppercase transition-colors duration-200 whitespace-nowrap flex-shrink-0"
         
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Featured artikel -->
    <a
      href={`/artikler/${featured.slug}`}
      x-show={`activeCategory === 'Alt' || activeCategory === '${featured.category}'`}
      class="block relative overflow-hidden group h-[300px] md:h-[580px]"
    >
      <img src={featured.img} alt={featured.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 px-6 md:px-12 py-6 md:py-12">
        <span class="text-[10px] tracking-widest uppercase text-white/70 mb-3 block">{featured.category}</span>
        <h2 class="text-white text-2xl md:text-4xl font-bold leading-tight max-w-2xl mb-4">{featured.title}</h2>
        <p class="text-white/80 text-sm leading-relaxed max-w-xl mb-6">{featured.teaser}</p>
        <div class="flex items-center gap-4 text-[10px] tracking-widest uppercase text-white/60">
          <span>{featured.author}</span>
          <span>·</span>
          <span>{featured.date}</span>
          <span>·</span>
          <span>{featured.readTime} læsning</span>
        </div>
      </div>
    </a>

    <!-- Artikel grid -->
    <div class="px-6 md:px-12 py-10 md:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-10 md:gap-y-14">
        {rest.map((article) => (
          <article
            x-show={`activeCategory === 'Alt' || activeCategory === '${article.category}'`}
            class="group flex flex-col"
          >
            <a href={`/artikler/${article.slug}`} class="block overflow-hidden bg-gray-100 aspect-[16/10] mb-5">
              <img
                src={article.img}
                alt={article.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </a>

            <span class="text-[10px] tracking-widest uppercase text-gray-400 mb-2 block">{article.category}</span>

            <a href={`/artikler/${article.slug}`}>
              <h3 class="text-sm font-semibold leading-snug mb-3 group-hover:underline underline-offset-2">{article.title}</h3>
            </a>

            <p class="text-xs text-gray-600 leading-relaxed mb-4 flex-1">{article.teaser}</p>

            <div class="flex items-center gap-3 text-[10px] tracking-widest uppercase text-gray-400">
              <span>{article.author}</span>
              <span>·</span>
              <span>{article.readTime}</span>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-16">
        <button type="button" class="border border-black text-xs tracking-widest uppercase px-10 py-3.5 hover:bg-black hover:text-white transition-colors duration-300">
          Indlæs flere artikler
        </button>
      </div>
    </div>

  </div>
</MainLayout>
