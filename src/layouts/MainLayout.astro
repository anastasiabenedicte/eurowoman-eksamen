---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import NewsletterPopup from "../components/NewsletterPopup.astro";
import '../styles/tailwind.css';
const { title } = Astro.props;
const description = Astro.props.description || "Danmarks førende mode- og kulturmagasin siden 1998. Mode, skønhed, kultur og livsstil.";
---
<html lang="da">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="da_DK" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={Astro.props.title} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Gloock&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700;1,800&display=swap" rel="stylesheet" />
<script>
			document.addEventListener('alpine:init', () => {
				Alpine.store('cart', {
					items: JSON.parse(localStorage.getItem('ew_cart') || '[]'),
					add(item) {
						const existing = this.items.find(i => i.issue === item.issue);
						if (existing) { existing.qty++; } else { this.items.push({ ...item, qty: 1 }); }
						localStorage.setItem('ew_cart', JSON.stringify(this.items));
					},
					remove(issue) {
						this.items = this.items.filter(i => i.issue !== issue);
						localStorage.setItem('ew_cart', JSON.stringify(this.items));
					},
					updateQty(issue, qty) {
						const item = this.items.find(i => i.issue === issue);
						if (item) { item.qty = Math.max(1, parseInt(qty) || 1); }
						localStorage.setItem('ew_cart', JSON.stringify(this.items));
					},
					get count() { return this.items.reduce((s, i) => s + i.qty, 0); },
					get subtotal() { return this.items.reduce((s, i) => s + i.price * i.qty, 0); },
					get shipping() { return this.items.length > 0 ? 49 : 0; },
					get total() { return this.subtotal + this.shipping; }
				});
			});
		</script>
	</head>
	<body class="min-h-screen flex flex-col">

		<header class="w-full">
			<Header />
		</header>
		
		<main class="flex-1">
			<slot />
		</main>

		<div>
			<Footer></Footer>
		</div>

		<NewsletterPopup />

	</body>
</html>