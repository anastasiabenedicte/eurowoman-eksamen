---
import { shopProducts } from "../data/shopProducts";
---

<section class="px-6 md:px-12 py-10 md:py-16">
  <div class="grid grid-cols-2 md:grid-cols-3 gap-x-4 md:gap-x-8 gap-y-10 md:gap-y-16">
    {shopProducts.map((p) => (
      <div class="group flex flex-col">

        <a href={`/shop/${p.id}`} class="block overflow-hidden bg-gray-100 aspect-square">
          <img
            src={p.img}
            alt={p.shopTitle}
            class="w-full h-full object-contain p-8 group-hover:scale-105 transition-transform duration-500"
          />
        </a>

        <div class="mt-4">
          <div class="flex items-center gap-2 mb-2">
            {p.isNy && (
              <span class="text-[10px] tracking-widest uppercase font-semibold border border-black px-1 py-px">Ny</span>
            )}
            <span class="text-[10px] tracking-widest uppercase text-gray-400">Produkt</span>
          </div>
          <a href={`/shop/${p.id}`}>
            <p class="text-xs tracking-widest uppercase font-medium leading-snug hover:underline">{p.shopTitle}</p>
          </a>
          <p class="text-xs text-gray-400 mt-2">{p.price} kr.</p>
        </div>

        <button
          type="button"
          x-data
          @click={`$store.cart.add({ issue: ${p.id}, title: '${p.shopTitle}', price: ${p.price}, img: '${p.img}' })`}
          class="mt-4 w-full border border-black text-xs tracking-widest uppercase py-2.5 hover:bg-black hover:text-white transition-colors duration-300"
        >
          Læg i kurv
        </button>

      </div>
    ))}
  </div>
</section>
