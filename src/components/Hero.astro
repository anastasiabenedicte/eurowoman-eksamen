---
---
<section class="grid grid-cols-1 md:grid-cols-2 min-h-screen overflow-hidden">

  <!-- Venstre: editorial tekst-panel -->
  <div class="relative flex flex-col justify-center p-8 md:p-14 min-h-[80vw] md:min-h-screen overflow-hidden">

    <!-- Baggrundsbillede -->
    <img
      src="/billeder/EUROWOMAN_OLOFSSON_HAMLIN__016.jpeg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <!-- Overlay: lyst for læsbarhed -->
    <div class="absolute inset-0 bg-white/90"></div>

    <!-- Indhold: centreret -->
    <div class="relative z-10">
      <p class="text-[10px] tracking-widest uppercase text-gray-500 mb-3">Eurowoman · Magasinet</p>
      <p class="text-sm text-gray-600 leading-relaxed max-w-[300px] mb-8">
        Danmarks mode- og kulturmagasin siden 1998 — et indvendigt blik på de historier der fortæller hvem vi er, hvad vi bærer, og hvad der bevæger os.
      </p>
      <h1 class="font-serif text-[clamp(2.8rem,6vw,5rem)] leading-[0.9] tracking-tight text-gray-900 mb-5">
        Læs med<br />hver måned.
      </h1>
      <p class="text-xs text-gray-600 mb-8 leading-relaxed">
        Få adgang til alt indhold · Fra 49 kr./md. · Opsig når som helst
      </p>
      <a
        href="/abonner"
        class="block w-full bg-black text-white text-xs tracking-widest uppercase py-4 text-center hover:opacity-70 transition-opacity mb-4"
      >
        Bliv abonnent
      </a>
      <a href="/shop" class="text-[10px] tracking-widest uppercase text-gray-500 hover:text-black transition-colors">
        Køb løssalg →
      </a>
    </div>

  </div>

  <!-- Højre: artikel-stil med gradient overlay -->
  <div class="relative overflow-hidden min-h-[90vw] md:min-h-screen">

    <img
      src="/mennesker/IMG_6699.jpeg"
      alt="Eurowoman nr. 341 – Juni 2026"
      class="absolute inset-0 w-full h-full object-cover object-top"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>

    <!-- Tekst i bunden -->
    <div class="absolute bottom-0 left-0 right-0 px-8 md:px-12 py-8 md:py-12">
      <span class="text-[10px] tracking-widest uppercase text-white/70 mb-3 block">Artikel</span>
      <h2 class="font-serif text-white text-2xl md:text-4xl leading-tight mb-4">
        Vi guider til det<br />perfekte par JEANS
      </h2>
      <p class="text-white/80 text-sm leading-relaxed max-w-sm mb-6">
        Fra slim fit til wide leg — vi hjælper dig med at finde det par jeans der sidder perfekt til din krop, din stil og din hverdag.
      </p>
      <div class="flex items-center gap-3 text-[10px] tracking-widest uppercase text-white/60 mb-6">
        <span>Juni 2026</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/artikler" class="text-[10px] tracking-widest uppercase text-white border border-white/60 px-5 py-2.5 hover:bg-white hover:text-black transition-colors duration-300">
          Læs artiklen
        </a>
      </div>
    </div>

  </div>

</section>
