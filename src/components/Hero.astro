---
---
<section class="grid grid-cols-1 md:grid-cols-2 overflow-hidden">

  <!-- Venstre: seneste magasin -->
  <div class="bg-gray-100 flex flex-col items-center justify-center py-10 px-6 md:py-16 md:px-20 gap-6">
    <div style="filter: drop-shadow(0 20px 40px rgba(0,0,0,0.18));">
      <img
        src="/forsider/EUW 2026 341 ForsideFinal.jpg"
        alt="Eurowoman nr. 341"
        class="w-full h-auto object-cover max-h-[75vh]"
      />
    </div>
    <div class="flex items-center gap-4">
      <span class="text-[10px] tracking-widest uppercase text-gray-400">Nr. 341</span>
      <span class="w-px h-3 bg-gray-300"></span>
      <span class="text-[10px] tracking-widest uppercase text-gray-400">Juni 2026</span>
      <span class="w-px h-3 bg-gray-300"></span>
      <span class="text-[10px] tracking-widest uppercase text-black">I salg nu</span>
    </div>
  </div>

  <!-- Højre: tekst -->
  <div class="flex flex-col items-center justify-between px-8 py-10 md:px-16 md:py-16 text-center min-h-[60vw] md:min-h-[90vh]">

    <!-- Top label -->
    <span class="text-xs tracking-[0.4em] uppercase text-gray-400">
      Siden 1998
    </span>

    <!-- Centrum: citat + knap -->
    <div class="flex flex-col items-center gap-10">
      <div class="w-px h-12 bg-gray-300"></div>

      <p class="text-2xl leading-relaxed text-gray-900 max-w-xs font-serif">
        Eurowoman er Danmarks førende mode- og kulturmagasin.
      </p>

      <a
        href="/abonner"
        class="relative group/btn border border-black text-xs tracking-widest uppercase px-16 py-4 overflow-hidden"
      >
        <span class="absolute inset-0 bg-black translate-y-full group-hover/btn:translate-y-0 transition-transform duration-300 ease-out"></span>
        <span class="relative text-black group-hover/btn:text-white transition-colors duration-300">Abonner</span>
      </a>
    </div>

    <!-- Bund: scroll indikator -->
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs tracking-widest uppercase text-gray-300">Scroll</span>
      <div class="w-px h-8 bg-gray-200 relative overflow-hidden">
        <div class="absolute top-0 w-full h-full bg-gray-300 animate-bounce"></div>
      </div>
    </div>

  </div>

</section>
