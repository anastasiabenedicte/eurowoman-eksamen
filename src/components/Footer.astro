---
---
<footer class="w-full border-t border-gray-100" id="footer">

  <!-- Back to top -->
  <a href="#" class="group flex flex-col items-center justify-center py-20 border-b border-gray-100 gap-4 transition-colors duration-500">
    <span class="text-2xl text-gray-300 group-hover:-translate-y-2 transition-transform duration-500">↑</span>
    <span
      class="uppercase tracking-[0.4em] text-sm text-gray-900 group-hover:tracking-[0.6em] transition-all duration-500"
     
    >
      Tilbage til toppen
    </span>
  </a>

  <!-- Abonnement sektion -->
  <div>

    <!-- Venstre: indhold -->
    <div class="px-12 py-12 flex flex-col justify-between max-w-2xl">

      <!-- Priser -->
      <div class="space-y-4 mb-10">
        <div class="flex items-baseline justify-between border-b border-gray-100 pb-3">
          <span class="text-sm tracking-wide">Årligt abonnement</span>
          <span class="text-sm font-medium">499 kr. / år</span>
        </div>
        <div class="flex items-baseline justify-between border-b border-gray-100 pb-3">
          <span class="text-sm tracking-wide text-gray-400">Digitalt abonnement</span>
          <span class="text-sm text-gray-400">249 kr. / år · 7 dages gratis prøveperiode</span>
        </div>
      </div>

      <!-- Beskrivelse -->
      <p class="text-sm text-gray-600 leading-loose max-w-md tracking-wide">
        Tolv udgaver af Eurowoman om året, leveret direkte til din dør —
        med fuld digital adgang til magasinets univers og eksklusive online indhold.
      </p>

      <!-- Log ind -->
      <div class="flex items-center gap-5 mt-10">
        <span class="text-xs tracking-widest uppercase text-gray-400">Allerede abonnent?</span>
        <a href="#" class="border border-black text-xs tracking-widest uppercase px-6 py-2.5 hover:bg-black hover:text-white transition-colors duration-300">
          Log ind
        </a>
      </div>

    </div>

  </div>

  <!-- Bund-bar -->
  <div class="border-t border-gray-100 px-6 md:px-12 py-5 flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">

    <span class="text-xs tracking-widest uppercase text-gray-300">&copy; Eurowoman 2026</span>

    <nav aria-label="Sidenavigation" class="flex flex-wrap justify-center gap-4 md:gap-8 text-xs tracking-widest uppercase text-gray-600">
      <a href="#" class="hover:text-black transition-colors duration-200">Kontakt</a>
      <a href="#" class="hover:text-black transition-colors duration-200">Artikler</a>
      <a href="#" class="hover:text-black transition-colors duration-200">Shop</a>
      <a href="#" class="hover:text-black transition-colors duration-200">Eurowoman</a>
      <a href="#" class="hover:text-black transition-colors duration-200">Magasiner</a>
      <a href="#" class="hover:text-black transition-colors duration-200">Abonnent</a>
    </nav>

    <nav aria-label="Sociale medier" class="flex gap-5 text-xs tracking-widest uppercase font-medium">
      <a href="#" class="hover:text-gray-400 transition-colors duration-200">Instagram</a>
      <a href="#" class="hover:text-gray-400 transition-colors duration-200">Pinterest</a>
      <a href="#" class="hover:text-gray-400 transition-colors duration-200">X</a>
    </nav>

  </div>

</footer>
