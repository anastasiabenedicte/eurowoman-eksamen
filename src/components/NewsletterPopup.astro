---
const images = [
  '/kampagner/Acne x Willow_FW24 Campaign_No Logo_2x3_1.jpg',
  '/kampagner/Chanel x Margot.jpeg',
  '/kampagner/Kendall x CK.jpg',
  '/kampagner/timberland x NAOMI-02-FINAL.jpg',
];
---

<div
  x-data="{
    open: false,
    currentImage: 0,
    email: '',
    _interval: null,
    startCycle() {
      this.stopCycle();
      this.currentImage = 0;
      const self = this;
      this._interval = setInterval(function() {
        self.currentImage = (self.currentImage + 1) % 4;
      }, 600);
    },
    stopCycle() {
      if (this._interval) { clearInterval(this._interval); this._interval = null; }
    },
    close() { this.open = false; this.stopCycle(); },
    submit() {
      if (this.email) { this.close(); }
    }
  }"
  x-show="open"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60"
  @click.self="close()"
  @open-newsletter.window="open = true; startCycle()"
  style="display:none"
>
  <div class="relative flex w-full max-w-4xl shadow-2xl" style="height:580px;">

    <!-- Luk-knap -->
    <button
      type="button"
      @click="close()"
      aria-label="Luk"
      class="absolute top-4 right-5 z-20 text-white text-2xl font-light leading-none hover:opacity-60 transition-opacity"
    >&#x2715;</button>

    <!-- Venstre: cyklerende billeder -->
    <div class="relative w-1/2 bg-black overflow-hidden flex-shrink-0">
      {images.map((src, i) => (
        <img
          src={src}
          alt=""
          class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
          x-bind:class={`currentImage === ${i} ? 'opacity-100' : 'opacity-0'`}
        />
      ))}
    </div>

    <!-- Højre: formular -->
    <div class="w-1/2 bg-white flex flex-col justify-center px-14 py-12">
      <h2 class="text-popup leading-tight mb-6 font-serif">
        Det sker, <em>før det sker.</em>
      </h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-10">
        Nye historier. Kommende kampagner. Et smugkig på hvad vi arbejder med — direkte i din indbakke, før bladet er i kiosken.
      </p>
      <input
        type="email"
        x-model="email"
        placeholder="din@mail.dk"
        class="w-full border-0 border-b border-gray-300 focus:border-black outline-none py-2 text-sm bg-transparent mb-8 placeholder:text-gray-300"
      />
      <button
        type="button"
        @click="submit()"
        class="w-full bg-black text-white py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-gray-800 transition-colors"
      >
        Tilmeld dig vores månedlige nyhedsbrev
      </button>
    </div>

  </div>
</div>
